# Copiar para .env e preencher os valores
# O ficheiro .env nunca deve ser commitado (está no .gitignore)

FLASK_ENV=development
SECRET_KEY=gera-uma-chave-forte-aqui

# Wise API
WISE_API_KEY=your_wise_api_key_here

# Notificações — Telegram
# Obter em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Notificações — SendGrid
# Obter em: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Assistente de IA
# Obter em openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free # Modelo escolhido para o assistente de IA, pode ser ajustado conforme necessário